<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
    </startup>
    <appSettings>
        <!-- DeepSeek API Key. Override at runtime via the Settings panel; the value is persisted to user.config. -->
        <add key="DeepSeek.ApiKey" value=""/>
        <!-- DeepSeek base endpoint. Use https://api.deepseek.com for the official service. -->
        <add key="DeepSeek.BaseUrl" value="https://api.deepseek.com"/>
        <!-- Default model id. deepseek-chat / deepseek-reasoner / deepseek-coder. -->
        <add key="DeepSeek.Model" value="deepseek-chat"/>
        <!-- Sampling temperature, 0.0 - 2.0 -->
        <add key="DeepSeek.Temperature" value="0.7"/>
        <!-- Maximum tokens for a single response -->
        <add key="DeepSeek.MaxTokens" value="2048"/>
        <!-- HTTP request timeout, in seconds -->
        <add key="DeepSeek.TimeoutSeconds" value="120"/>
        <!-- Default system prompt for the assistant -->
        <add key="DeepSeek.SystemPrompt" value="你是专门服务海康机器人 VisionMaster/VM 平台的中文 AI 助手，优先基于已检索到的平台说明手册回答；当手册资料不足时要明确说明，并给出谨慎的工程建议。"/>
        <add key="VmManualRag.Enabled" value="true"/>
        <add key="VmManualRag.ChmPath" value="c:\Users\Administrator\Downloads\HikRobotVMHelp (2).chm"/>
        <add key="VmManualRag.IndexDirectory" value=""/>
        <add key="VmManualRag.TopK" value="4"/>
        <add key="VmManualRag.MaxContextChars" value="6000"/>
    </appSettings>
</configuration>
